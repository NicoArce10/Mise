# Copy to .env and fill in. Never commit .env.

# --- Anthropic (required for AI core) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-7

# --- Backend ---
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Pipeline mode: `mock` (fast fixture walk, no pipeline code),
# `fallback` (real pipeline with deterministic extraction — recommended
# for the demo recording), or `real` (calls Opus 4.7; requires API key
# and billed credits). Defaults to `mock` so a fresh clone boots.
MISE_PIPELINE_MODE=mock

# --- Frontend (Vite) ---
# All public vars MUST start with VITE_
VITE_API_BASE=http://127.0.0.1:8000

# External DB (Supabase / Postgres) is out of MVP scope. The JSON catalog
# served at `/api/catalog/{run_id}.json` is the external contract.
