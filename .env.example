# Copy to .env and fill in. Never commit .env.

# --- Anthropic (required for AI core) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-7

# --- Backend ---
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Frontend (Vite) ---
# All public vars MUST start with VITE_
VITE_API_BASE=http://127.0.0.1:8000

# External DB (Supabase / Postgres) is OUT of MVP scope — see docs/scope_freeze.md.
# Do not reintroduce without unfreezing scope per that doc.
